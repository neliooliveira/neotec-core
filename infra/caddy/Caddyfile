# Caddyfile for NEOTEC Core
# Reverse proxy and HTTPS configuration

{
  # Global options
  email {$CADDY_EMAIL:admin@neotec.com}
  
  # Allow Caddy to use placeholders
  on_demand_tls {
    ask http://frontend:3000/health
  }
}

# Development configuration
http://localhost {
  # Frontend
  route / {
    reverse_proxy frontend:3000
  }

  # Backend API
  route /api/* {
    uri strip_prefix /api
    reverse_proxy backend:8000
  }

  # Django Admin
  route /admin/* {
    reverse_proxy backend:8000
  }

  # Static files
  route /static/* {
    reverse_proxy backend:8000
  }

  # Media files
  route /media/* {
    reverse_proxy backend:8000
  }
}

# Production HTTPS (when deployed with domain)
